# Copy to .env on server — never commit .env
# فیلتر درخواست (SQLi / …) — برای غیرفعال کردن در توسعه: WAF_DISABLE=1
# WAF_DISABLE=0
# Zoho SMTP (contact.php, report.php, careers-apply.php)
ZOHO_EMAIL=hello@iraniu.uk
ZOHO_PASSWORD=your_zoho_app_password_here
ADMIN_EMAIL=hello@iraniu.uk
# اختیاری: رزومه به این ایمیل هم می‌رود (careers-apply.php)؛ اگر خالی باشد = ADMIN_EMAIL
# CAREERS_EMAIL=hr@iraniu.uk

# Cloudflare Turnstile (فرم‌ها) — کلید مخفی، نه site key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here

# MySQL — اخبار (blog/news.php) جدول tbl_news
# (نام‌های لاراولی؛ DB_NAME/DB_USER همچنین پشتیبانی می‌شوند)
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=cybercinaco_app
DB_USERNAME=cybercinaco_app
DB_PASSWORD=your_db_password_here
# اختیاری: آدرس پایه برای مسیر نسبی تصویر در دیتابیس
# NEWS_IMAGE_BASE_URL=https://example.com
# نام جدول دسته‌ها (پیش‌فرض tbl_category)
# NEWS_CATEGORY_TABLE=tbl_category

# لینک دانلود اپ (صفحه جزئیات خبر)
# APP_STORE_URL=https://apps.apple.com/us/app/iraniu/id6760209069
# GOOGLE_PLAY_URL=https://play.google.com/...
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_MODEL=gpt-4o-mini
# WHATSAPP_NUMBER=447000000000

# آدرس کانونیکال سایت (اختیاری؛ برای ریدایرکت ?id= و محیط لوکال)
# SITE_URL=https://iraniu.uk
# امضای لینک مقالات /blog/article/{token} — در پروداکشن یک رشته تصادفی طولانی بگذارید
# ARTICLE_URL_SECRET=
