# Zoho SMTP Configuration
# Copy this file to .env and fill in your credentials
ZOHO_EMAIL=hello@iraniu.uk
ZOHO_PASSWORD=your_zoho_password_here
ADMIN_EMAIL=hello@iraniu.uk

# MySQL — اخبار (blog/news.php) جدول tbl_news
# (نام‌های لاراولی؛ DB_NAME/DB_USER همچنین پشتیبانی می‌شوند)
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=cybercinaco_app
DB_USERNAME=cybercinaco_app
DB_PASSWORD=your_db_password_here
# اختیاری: آدرس پایه برای مسیر نسبی تصویر در دیتابیس
# NEWS_IMAGE_BASE_URL=https://example.com
